ini # ================================================================= # WORKFLOW AUTOMATION CONFIGURATION (n8n) # ================================================================= # Server Setup N8N_HOST=localhost N8N_PORT=5678 N8N_PROTOCOL=http # Database Infrastructure (PostgreSQL for heavy data) DB_TYPE=postgresdb DB_POSTGRESDB_DATABASE=n8n_ramon_db DB_POSTGRESDB_HOST=localhost DB_POSTGRESDB_PORT=5432 DB_POSTGRESDB_USER=n8n_admin DB_POSTGRESDB_PASSWORD=ENTER_SECURE_PASSWORD # Encryption Key (Keep empty in template) N8N_ENCRYPTION_KEY=ENTER_YOUR_SECURE_KEY